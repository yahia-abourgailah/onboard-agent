# Copy to .env for local development: cp .env.example .env
# Real values per environment live in the platform's secret store, never in git.

# One of: development | staging | production
# NOTE: no ONBOARD_ prefix — see the env_prefix comment in config.py.
ENVIRONMENT=development
DEBUG=true

# OpenAI-compatible LLM endpoint (local vLLM server in prod).
OPENAI_API_KEY=
OPENAI_BASE_URL=
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_ENDPOINT=
# Shared bearer token clients must send as: Authorization: Bearer <token>
# Generate one with: python token_generator.py
API_TOKEN=

# JSON list of browser origins allowed by CORS (empty = no cross-origin).
# Example: CORS_ALLOW_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_ORIGINS=[]

