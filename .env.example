# Copy to .env for local development: cp .env.example .env
# Real values per environment live in the platform's secret store, never in git.

# One of: development | staging | production
ONBOARD_ENVIRONMENT=development
ONBOARD_DEBUG=true

#API keys for the LLM service. These are used to authenticate requests to the LLM API.
OPENAI_BASE_URL=
OPENAI_API_KEY=

MODEL_NAME=
TEMPERATURE=

# Secret token clients send as: Authorization: Bearer <API_TOKEN>
API_TOKEN=
